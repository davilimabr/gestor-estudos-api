{
  "info": {
    "name": "Gestor-Estudos API",
    "_postman_id": "7f0b135b-4d29-4113-bd46-a1f50f3b9c0e",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:3000" },
    { "key": "token_gestor", "value": "" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      { "key": "token", "value": "{{token_gestor}}", "type": "string" }
    ]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [],
            "url": { "raw": "{{base_url}}/api/auth/register", "host": ["{{base_url}}"], "path": ["api", "auth", "register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Admin\",\n  \"email\": \"admin@email.com\",\n  \"password\": \"1234\",\n  \"role\": \"ADMIN\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [],
            "url": { "raw": "{{base_url}}/api/auth/login", "host": ["{{base_url}}"], "path": ["api", "auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@email.com\",\n  \"password\": \"1234\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  if (json.token) {",
                  "    pm.collectionVariables.set('token_gestor', json.token);",
                  "    pm.environment.set('token_gestor', json.token);",
                  "  }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },

    
    {
      "name": "Users",
      "item": [
        {
          "name": "Create User",
          "request": {
            "method": "POST",
            "url": { "raw": "{{base_url}}/api/users", "host": ["{{base_url}}"], "path": ["api", "users"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Fulano\",\n  \"email\": \"fulano@email.com\",\n  \"password\": \"1234\",\n  \"role\": \"STUDENT\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        { "name": "List Users", "request": { "method": "GET", "url": "{{base_url}}/api/users" } },
        {
          "name": "Get User by ID",
          "request": { "method": "GET", "url": "{{base_url}}/api/users/1" }
        },
        {
          "name": "Update User",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/api/users/1",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Fulano de Tal\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        { "name": "Delete User", "request": { "method": "DELETE", "url": "{{base_url}}/api/users/1" } }
      ]
    },

